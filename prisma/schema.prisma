generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id          String   @id @default(cuid())
  entraId     String?  @unique
  name        String
  email       String   @unique
  avatarUrl   String?
  accentColor String   @default("blue")
  theme       String   @default("light")
  createdAt   DateTime @default(now())

  pages     Page[]
  revisions Revision[]
  pageViews PageView[]
  pageLikes PageLike[]
  questions Question[]
  answers   Answer[]
  comments  Comment[]
  templates Template[]
}

model Page {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String   @default("")
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author    User       @relation(fields: [authorId], references: [id])
  tags      PageTag[]
  revisions Revision[]
  pageViews PageView[]
  likes     PageLike[]
  aiSummary AISummary?

  outgoingLinks PageLink[] @relation("SourcePage")
  incomingLinks PageLink[] @relation("TargetPage")
  comments      Comment[]
}

model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  pages     PageTag[]
}

model PageTag {
  pageId          String
  tagId           String
  isAutoGenerated Boolean @default(false)

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([pageId, tagId])
}

model Revision {
  id        String   @id @default(cuid())
  pageId    String
  content   String
  authorId  String
  createdAt DateTime @default(now())

  page   Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])
}

model PageView {
  id       String   @id @default(cuid())
  pageId   String
  userId   String
  viewedAt DateTime @default(now())

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([pageId])
  @@index([userId])
}

model AISummary {
  id        String   @id @default(cuid())
  pageId    String   @unique
  summary   String
  createdAt DateTime @default(now())

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
}

model PageLink {
  sourcePageId String
  targetPageId String

  sourcePage Page @relation("SourcePage", fields: [sourcePageId], references: [id], onDelete: Cascade)
  targetPage Page @relation("TargetPage", fields: [targetPageId], references: [id], onDelete: Cascade)

  @@id([sourcePageId, targetPageId])
}

model PageLike {
  pageId    String
  userId    String
  createdAt DateTime @default(now())

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@id([pageId, userId])
  @@index([pageId])
}

model Question {
  id           String   @id @default(cuid())
  title        String
  content      String
  authorId     String
  status       String   @default("open")
  bestAnswerId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  author  User     @relation(fields: [authorId], references: [id])
  answers Answer[]

  @@index([authorId])
}

model Answer {
  id         String   @id @default(cuid())
  content    String
  authorId   String
  questionId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  author   User     @relation(fields: [authorId], references: [id])
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@index([authorId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  pageId    String
  authorId  String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  page    Page      @relation(fields: [pageId], references: [id], onDelete: Cascade)
  author  User      @relation(fields: [authorId], references: [id])
  parent  Comment?  @relation("CommentThread", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentThread")

  @@index([pageId])
  @@index([parentId])
}

model Template {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  content     String   @default("")
  category    String   @default("general")
  authorId    String
  isBuiltIn   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id])

  @@index([category])
}
